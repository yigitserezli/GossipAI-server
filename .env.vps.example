# VPS public IP/domain for nginx server_name
DOMAIN=example.com
CERTBOT_PRIMARY_DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# Postgres
POSTGRES_DB=gossipai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4321
ADMIN_PASSCODE=180704
DEVELOPER_EMAILS=dev@example.com
JWT_ACCESS_SECRET=change_this_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-5.2
OPENAI_ASSISTANT_ID=
OPENAI_WORKFLOW_ID=
OPENAI_WORKFLOW_VERSION=
OPENAI_WORKFLOW_NAME=Tier3_Rosie
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
EXPO_PUSH_ACCESS_TOKEN=
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_SCHEDULER_CRON=0 9,21 * * *
NOTIFICATION_SCHEDULER_TIMEZONE=UTC
DAILY_INSIGHT_SCHEDULER_ENABLED=true
DAILY_INSIGHT_SCHEDULER_CRON=5 0 * * *
DAILY_INSIGHT_SCHEDULER_TIMEZONE=UTC

# Optional Firebase (only if using non-Expo tokens)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
